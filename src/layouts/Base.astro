---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SearchPalette from '../components/SearchPalette.astro';
import { site } from '../config';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  /** Absolute or site-relative path to a social-card image */
  image?: string;
  /** "wide" (default) or "prose" — prose narrows the main content for readability */
  width?: 'wide' | 'prose';
}

const { title, description, image, width = 'wide' } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.title;
const pageDesc = description ?? site.description;
const ogImage = new URL(image ?? '/og-default.png', Astro.site ?? Astro.url.origin).toString();
const containerClass = width === 'prose' ? 'container-prose' : 'container-page';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <ClientRouter />
    <script is:inline>
      // Apply theme pre-paint to avoid flash
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          const theme = stored || system;
          document.documentElement.dataset.theme = theme;
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main class={`${containerClass} pt-24 pb-24`}>
      <slot />
    </main>
    <Footer />
    <SearchPalette />

    <script>
      function setupReveal() {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }
      setupReveal();
      document.addEventListener('astro:page-load', setupReveal);
    </script>
  </body>
</html>
