---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, category, tech, status } = project.data;
const href = `/projects/${project.id}`;
---

<a href={href} class="group block rounded-lg border p-5 transition-all reveal" style="border-color: var(--color-border); background: var(--color-bg-soft);">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="mb-2 flex items-center gap-2 text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
        <span>{category}</span>
        {status !== 'shipped' && (
          <>
            <span>·</span>
            <span style={status === 'in-progress' ? 'color: var(--color-accent);' : ''}>{status}</span>
          </>
        )}
      </div>
      <h3 class="text-lg font-semibold transition-colors group-hover:text-[var(--color-accent)]">
        {title}
      </h3>
      <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-fg-muted);">
        {summary}
      </p>
    </div>
    <span class="mt-1 shrink-0 text-sm transition-transform group-hover:translate-x-0.5" style="color: var(--color-fg-dim);">
      →
    </span>
  </div>
  {tech.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tech.slice(0, 5).map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</a>
