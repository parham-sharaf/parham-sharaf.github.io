---
import type { CollectionEntry } from 'astro:content';
import { site } from '../config';

interface Props {
  pub: CollectionEntry<'publications'>;
  compact?: boolean;
}

const { pub, compact = false } = Astro.props;
const { title, authors, venue, date, tldr, role, arxiv, pdf, code, project, tags } = pub.data;

const year = date.getFullYear();
const aliases = site.authorAliases as readonly string[];
const isMe = (name: string) => aliases.some((a) => a.toLowerCase() === name.toLowerCase());

const links = [
  arxiv && { label: 'arXiv', href: `https://arxiv.org/abs/${arxiv}` },
  pdf && { label: 'PDF', href: pdf },
  code && { label: 'Code', href: code },
  project && { label: 'Project', href: project },
].filter(Boolean) as { label: string; href: string }[];
---

<article class="reveal group py-6">
  <div class="flex items-baseline gap-3 mb-2 text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
    <span>{venue}</span>
    <span>·</span>
    <span>{year}</span>
    {role && (
      <>
        <span>·</span>
        <span>{role.toLowerCase()}</span>
      </>
    )}
  </div>

  <h3 class={`${compact ? 'text-base' : 'text-lg'} font-semibold leading-snug`}>
    {title}
  </h3>

  <p class="mt-2 text-sm leading-relaxed">
    {authors.map((name, i) => (
      <>
        <span style={isMe(name) ? 'color: var(--color-fg); font-weight: 600;' : 'color: var(--color-fg-muted);'}>
          {name}
        </span>
        {i < authors.length - 1 && <span style="color: var(--color-fg-dim);">, </span>}
      </>
    ))}
  </p>

  {!compact && (
    <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-fg-muted);">
      {tldr}
    </p>
  )}

  {(links.length > 0 || tags.length > 0) && (
    <div class="mt-4 flex flex-wrap items-center gap-2">
      {links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1 rounded-md border px-2.5 py-1 text-xs transition-colors hover:bg-[var(--color-surface)] hover:border-[var(--color-accent)]"
          style="border-color: var(--color-border-strong); font-family: var(--font-mono); color: var(--color-fg-muted);"
        >
          {l.label} ↗
        </a>
      ))}
      {!compact && tags.length > 0 && (
        <span class="ml-1 flex flex-wrap gap-1.5">
          {tags.map((t) => <span class="tag">#{t}</span>)}
        </span>
      )}
    </div>
  )}
</article>
