---
// Image lightbox: attaches click handlers to all images inside .prose-custom.
// On click, opens a full-screen overlay with the clicked image. Click outside
// or press ESC to close. Supports arrow-key navigation between images.
---

<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
  <button type="button" class="lightbox-close" aria-label="Close image">✕</button>
  <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">‹</button>
  <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">›</button>
  <figure class="lightbox-figure">
    <img id="lightbox-img" alt="" />
    <figcaption id="lightbox-cap" class="lightbox-caption"></figcaption>
  </figure>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 6, 8, 0.94);
    backdrop-filter: blur(6px);
    padding: 2rem;
    opacity: 0;
    transition: opacity 180ms ease;
  }
  .lightbox[hidden] {
    display: none !important;
  }
  .lightbox.is-open {
    opacity: 1;
  }
  .lightbox-figure {
    max-width: 100%;
    max-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin: 0;
  }
  .lightbox-figure img {
    max-width: 96vw;
    max-height: 86vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
    background: var(--color-bg-soft);
  }
  .lightbox-caption {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    text-align: center;
    max-width: 60ch;
    line-height: 1.45;
  }
  .lightbox-caption:empty {
    display: none;
  }
  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    background: rgba(20, 20, 22, 0.7);
    color: var(--color-fg);
    border: 1px solid var(--color-border-strong);
    border-radius: 9999px;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    transition: all 160ms ease;
  }
  .lightbox-close:hover,
  .lightbox-nav:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg);
  }
  .lightbox-close {
    top: 1.25rem;
    right: 1.25rem;
  }
  .lightbox-prev {
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.75rem;
  }
  .lightbox-next {
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.75rem;
  }
  .lightbox-nav[hidden] {
    display: none !important;
  }

  /* Make inline content images signal their clickability */
  .prose-custom img {
    cursor: zoom-in;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLDivElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxCap = document.getElementById('lightbox-cap') as HTMLElement | null;
  const prevBtn = lightbox?.querySelector('.lightbox-prev') as HTMLButtonElement | null;
  const nextBtn = lightbox?.querySelector('.lightbox-next') as HTMLButtonElement | null;
  const closeBtn = lightbox?.querySelector('.lightbox-close') as HTMLButtonElement | null;

  if (lightbox && lightboxImg && lightboxCap) {
    // Gather all content images up front — only inside the prose area so cards/UI aren't included.
    const images = Array.from(
      document.querySelectorAll<HTMLImageElement>('.prose-custom img'),
    );
    let currentIndex = -1;

    function show(i: number) {
      if (i < 0 || i >= images.length) return;
      currentIndex = i;
      const src = images[i].getAttribute('src') ?? '';
      const alt = images[i].getAttribute('alt') ?? '';
      lightboxImg!.src = src;
      lightboxImg!.alt = alt;
      lightboxCap!.textContent = alt;
      lightbox!.hidden = false;
      requestAnimationFrame(() => lightbox!.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
      updateNavVisibility();
    }

    function hide() {
      lightbox!.classList.remove('is-open');
      setTimeout(() => {
        lightbox!.hidden = true;
        lightboxImg!.src = '';
      }, 180);
      document.body.style.overflow = '';
    }

    function step(delta: number) {
      if (currentIndex < 0) return;
      const next = currentIndex + delta;
      if (next < 0 || next >= images.length) return;
      show(next);
    }

    function updateNavVisibility() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.hidden = currentIndex <= 0;
      nextBtn.hidden = currentIndex >= images.length - 1;
    }

    images.forEach((img, i) => {
      img.addEventListener('click', (e) => {
        e.preventDefault();
        show(i);
      });
    });

    closeBtn?.addEventListener('click', hide);
    prevBtn?.addEventListener('click', () => step(-1));
    nextBtn?.addEventListener('click', () => step(1));

    lightbox.addEventListener('click', (e) => {
      // Click on backdrop (not the figure) closes
      if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-figure')) {
        hide();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') hide();
      else if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  }
</script>
