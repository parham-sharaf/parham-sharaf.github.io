---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationItem from '../components/PublicationItem.astro';
import { getCollection } from 'astro:content';
import { site } from '../config';
import { aggregateCategories, aggregateTech, coverImage, sortedProjects } from '../utils/project';

const allProjects = sortedProjects(await getCollection('projects'));
const featuredProjects = allProjects.filter((p) => p.data.featured).slice(0, 7);
const spotlight = featuredProjects[0];
const restFeatured = featuredProjects.slice(1, 7);

const pubs = (await getCollection('publications', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featuredPubs = pubs.filter((p) => p.data.featured).slice(0, 3);

const topTech = aggregateTech(allProjects).slice(0, 16);
const categoryCount = aggregateCategories(allProjects).length;

const years = allProjects.length
  ? new Date().getFullYear() - Math.min(...allProjects.map((p) => p.data.date.getFullYear())) + 1
  : 0;

const stats = [
  { label: 'Projects', value: allProjects.length },
  { label: 'Categories', value: categoryCount },
  { label: 'Publications', value: pubs.length },
  { label: 'Years building', value: years },
];

// Words that rotate in the headline
const rotatingWords = ['autonomy', 'controls', 'machine learning', 'robotics', 'computer vision'];
---

<Base>
  <!-- Hero -->
  <section class="hero pt-4 pb-16">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-grid-cols">
      <div class="hero-text">
        <p class="mb-6 text-xs reveal" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
          <span class="status-dot"></span>
          <span>{site.location}</span>
          <span class="mx-2" style="color: var(--color-border-strong);">·</span>
          <span>available May 2026</span>
        </p>

        <h1 class="hero-title reveal">
          <span class="hero-name">{site.shortName ?? site.name.split(' ')[0]}</span>
          <span class="hero-tail">
            builds systems for
            <span class="hero-rotate" data-words={JSON.stringify(rotatingWords)}>
              <span class="hero-rotate-word">{rotatingWords[0]}</span>
            </span>
          </span>
        </h1>

        <p class="hero-bio reveal">
          EECS &amp; MEng at UC Berkeley. Research on safe imitation learning, multi-agent
          coordination, and LLM reasoning. Currently shipping computer-vision pipelines at
          <span style="color: var(--color-fg);">IntuigenceAI</span>.
        </p>

        <div class="mt-7 flex flex-wrap gap-3 reveal">
          <a href={site.links.resume} download class="cta-primary">
            ↓ Resume
          </a>
          <a href="/projects" class="cta-secondary">Projects</a>
          <a href="/publications" class="cta-secondary">Publications</a>
          <a href="/about" class="cta-secondary">About</a>
          {site.links.github && (
            <a href={site.links.github} class="cta-secondary">GitHub ↗</a>
          )}
        </div>
      </div>

      <figure class="hero-portrait reveal" aria-hidden="false">
        <img
          src="/images/parham.jpg"
          alt={`Portrait of ${site.name}`}
          loading="eager"
          decoding="async"
        />
        <span class="hero-portrait-frame" aria-hidden="true"></span>
      </figure>
    </div>

    <!-- Now strip -->
    <a href="/now" class="now-strip reveal" aria-label="Currently working on">
      <span class="now-label">Now</span>
      <span class="now-text">
        Decentralized fleet coordination for airport ground ops · MEng thesis on safe imitation
        learning for race-car controllers
      </span>
      <span class="now-arrow" aria-hidden="true">→</span>
    </a>

    <!-- Stats row — hairline style -->
    <ul class="stats reveal">
      {stats.map((s, i) => (
        <li class="stat" data-i={i}>
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Spotlight project -->
  {spotlight && (
    <section class="pb-16 reveal">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="section-eyebrow">Selected work</h2>
        <a href="/projects" class="text-xs link-underline" style="color: var(--color-fg-muted); font-family: var(--font-mono);">
          all {allProjects.length} →
        </a>
      </div>

      <a href={`/projects/${spotlight.id}`} class="spotlight group">
        {coverImage(spotlight) && (
          <div class="spotlight-cover">
            <img
              src={coverImage(spotlight)!}
              alt=""
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
            />
            <div class="spotlight-fade"></div>
          </div>
        )}
        <div class="spotlight-meta">
          <div class="mb-2 flex items-center gap-2 text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
            <span>{spotlight.data.category}</span>
            <span>·</span>
            <span>{spotlight.data.date.getFullYear()}</span>
            {spotlight.data.status !== 'shipped' && (
              <>
                <span>·</span>
                <span style="color: var(--color-accent);">{spotlight.data.status}</span>
              </>
            )}
          </div>
          <h3 class="spotlight-title group-hover:text-[var(--color-accent)]">
            {spotlight.data.title}
          </h3>
          <p class="spotlight-summary">{spotlight.data.summary}</p>
          {spotlight.data.tech.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {spotlight.data.tech.slice(0, 6).map((t) => <span class="tag">{t}</span>)}
            </div>
          )}
          <span class="spotlight-cta">Read case study <span class="arrow">→</span></span>
        </div>
      </a>
    </section>
  )}

  <!-- Rest of featured projects -->
  {restFeatured.length > 0 && (
    <section class="pb-20">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {restFeatured.map((p) => <ProjectCard project={p} />)}
      </div>
    </section>
  )}

  <!-- Featured publications -->
  {featuredPubs.length > 0 && (
    <section class="pb-20">
      <div class="mb-6 flex items-baseline justify-between reveal">
        <h2 class="section-eyebrow">Selected publications</h2>
        <a href="/publications" class="text-xs link-underline" style="color: var(--color-fg-muted); font-family: var(--font-mono);">
          all →
        </a>
      </div>
      <div class="divide-y" style="border-color: var(--color-border);">
        {featuredPubs.map((p) => <PublicationItem pub={p} />)}
      </div>
    </section>
  )}

  <!-- Tech strip — moved below as supporting context, not headline -->
  {topTech.length > 0 && (
    <section class="pb-8 reveal">
      <p class="mb-3 text-xs tracking-wider uppercase" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
        Working with
      </p>
      <div class="flex flex-wrap gap-1.5">
        {topTech.map(({ tech, count }) => (
          <span class="tech-pill" title={`${count} project${count > 1 ? 's' : ''}`}>
            {tech}
            <span class="tech-pill-count">{count}</span>
          </span>
        ))}
      </div>
    </section>
  )}

  {allProjects.length === 0 && pubs.length === 0 && (
    <p class="text-sm" style="color: var(--color-fg-muted);">
      No content yet.
    </p>
  )}
</Base>

<style>
  /* Hero — animated radial glow + faint grid */
  .hero {
    position: relative;
    isolation: isolate;
  }
  .hero-glow {
    position: absolute;
    pointer-events: none;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 110%;
    height: 560px;
    z-index: -1;
    background:
      radial-gradient(900px 320px at 30% 40%, rgba(255, 106, 31, 0.14), transparent 65%),
      radial-gradient(640px 280px at 75% 60%, rgba(80, 140, 255, 0.09), transparent 65%);
    filter: blur(0.5px);
    animation: glow-shift 18s ease-in-out infinite alternate;
  }
  .hero-grid {
    position: absolute;
    inset: -120px -10% auto -10%;
    height: 580px;
    z-index: -1;
    pointer-events: none;
    background-image:
      linear-gradient(to right, var(--color-border) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-border) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 30%, #000 35%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 30%, #000 35%, transparent 75%);
    opacity: 0.55;
  }
  @keyframes glow-shift {
    0%   { transform: translateX(-52%) scale(1.0); opacity: 0.9; }
    50%  { transform: translateX(-48%) scale(1.05); opacity: 1; }
    100% { transform: translateX(-50%) scale(1.02); opacity: 0.85; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-glow { animation: none; }
  }

  /* Two-column hero — text left, portrait right (stacks on mobile) */
  .hero-grid-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-grid-cols {
      grid-template-columns: 1fr auto;
      gap: 3.5rem;
    }
  }
  .hero-text {
    min-width: 0; /* allow text to shrink within grid */
  }

  /* Portrait — circular, soft accent ring, drifts on hover */
  .hero-portrait {
    position: relative;
    width: 11rem;
    height: 11rem;
    margin: 0;
    justify-self: start;
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .hero-portrait {
      width: 14rem;
      height: 14rem;
      justify-self: end;
    }
  }
  @media (min-width: 1024px) {
    .hero-portrait {
      width: 16rem;
      height: 16rem;
    }
  }
  .hero-portrait img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 9999px;
    border: 1px solid var(--color-border-strong);
    box-shadow:
      0 24px 60px -28px rgba(0, 0, 0, 0.7),
      0 0 0 6px var(--color-bg);
    transition: transform 400ms ease, border-color 400ms ease, box-shadow 400ms ease;
  }
  .hero-portrait:hover img {
    transform: translateY(-3px) scale(1.015);
    border-color: var(--color-accent);
    box-shadow:
      0 30px 80px -24px rgba(255, 106, 31, 0.45),
      0 0 0 6px var(--color-bg);
  }
  /* Subtle accent ring behind the portrait */
  .hero-portrait-frame {
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    background: conic-gradient(
      from 140deg,
      rgba(255, 106, 31, 0.0) 0%,
      rgba(255, 106, 31, 0.35) 25%,
      rgba(255, 106, 31, 0.0) 55%,
      rgba(80, 140, 255, 0.18) 80%,
      rgba(255, 106, 31, 0.0) 100%
    );
    filter: blur(14px);
    opacity: 0.85;
    z-index: 0;
    animation: portrait-spin 22s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-portrait-frame {
      animation: none;
    }
  }
  @keyframes portrait-spin {
    to { transform: rotate(360deg); }
  }

  .status-dot {
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 106, 31, 0.18);
    margin-right: 0.5rem;
    vertical-align: 1px;
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(255, 106, 31, 0.16); }
    50%      { box-shadow: 0 0 0 6px rgba(255, 106, 31, 0.04); }
  }

  /* Headline */
  .hero-title {
    font-size: clamp(2.4rem, 6.4vw, 4.5rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--color-fg);
    max-width: 22ch;
  }
  .hero-name {
    background: linear-gradient(180deg, var(--color-fg) 0%, var(--color-fg-muted) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-tail {
    color: var(--color-fg-muted);
    font-weight: 500;
  }
  .hero-rotate {
    display: inline-block;
    color: var(--color-accent);
    position: relative;
  }
  .hero-rotate-word {
    display: inline-block;
    transition: opacity 220ms ease, transform 220ms ease;
  }
  .hero-rotate-word.is-out {
    opacity: 0;
    transform: translateY(-6px);
  }
  .hero-rotate-word.is-in {
    opacity: 0;
    transform: translateY(6px);
  }

  .hero-bio {
    margin-top: 1.5rem;
    max-width: 42rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-fg-muted);
  }

  /* CTA buttons */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.05rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    background: var(--color-accent);
    color: var(--color-bg);
    transition: all 160ms ease;
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px -6px rgba(255, 106, 31, 0.5);
  }
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.55rem 1.05rem;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border-strong);
    color: var(--color-fg-muted);
    transition: all 160ms ease;
  }
  .cta-secondary:hover {
    color: var(--color-fg);
    background: var(--color-surface);
    border-color: var(--color-fg-muted);
  }

  /* Now strip */
  .now-strip {
    margin-top: 2.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 1rem;
    border-radius: 0.6rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    transition: all 200ms ease;
  }
  .now-strip:hover {
    border-color: var(--color-border-strong);
    background: var(--color-surface);
  }
  .now-strip:hover .now-arrow {
    transform: translateX(3px);
    color: var(--color-accent);
  }
  .now-label {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-accent);
    border-radius: 9999px;
  }
  .now-text {
    flex: 1;
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.45;
  }
  .now-arrow {
    flex-shrink: 0;
    color: var(--color-fg-dim);
    transition: transform 200ms ease, color 200ms ease;
  }

  /* Stats — hairline style instead of card boxes */
  .stats {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  @media (min-width: 640px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .stat {
    padding: 1.1rem 1rem 1.1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    position: relative;
  }
  .stat + .stat::before {
    content: '';
    position: absolute;
    left: 0;
    top: 18%;
    bottom: 18%;
    width: 1px;
    background: var(--color-border);
  }
  .stat[data-i="2"]::before {
    display: none;
  }
  @media (min-width: 640px) {
    .stat {
      padding-left: 1.1rem;
    }
    .stat[data-i="0"] {
      padding-left: 0;
    }
    .stat[data-i="2"]::before {
      display: block;
    }
  }
  .stat-value {
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
  }

  /* Section eyebrow */
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
  }

  /* Spotlight (large featured project) */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    transition: all 220ms ease;
  }
  .spotlight:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: 0 18px 50px -24px rgba(255, 106, 31, 0.4);
  }
  @media (min-width: 768px) {
    .spotlight {
      grid-template-columns: 1.25fr 1fr;
    }
  }
  .spotlight-cover {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    aspect-ratio: 16 / 10;
  }
  @media (min-width: 768px) {
    .spotlight-cover {
      aspect-ratio: auto;
      min-height: 100%;
    }
  }
  .spotlight-fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(0,0,0,0) 60%, rgba(0,0,0,0.25) 100%);
  }
  .spotlight-meta {
    padding: 1.75rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .spotlight-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    transition: color 200ms ease;
  }
  .spotlight-summary {
    margin-top: 0.6rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-fg-muted);
  }
  .spotlight-cta {
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .spotlight-cta .arrow {
    transition: transform 200ms ease;
  }
  .spotlight:hover .spotlight-cta .arrow {
    transform: translateX(4px);
  }

  /* Tech pills */
  .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.6rem 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--color-fg-muted);
    transition: all 160ms ease;
  }
  .tech-pill:hover {
    color: var(--color-fg);
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .tech-pill-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.1rem;
    height: 1.1rem;
    padding: 0 0.3rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    background: var(--color-surface);
    color: var(--color-fg-dim);
  }
</style>

<script>
  // Rotating word in headline
  function setupRotator() {
    const wrap = document.querySelector<HTMLElement>('.hero-rotate');
    if (!wrap) return;
    const span = wrap.querySelector<HTMLElement>('.hero-rotate-word');
    if (!span) return;
    let words: string[] = [];
    try {
      words = JSON.parse(wrap.dataset.words || '[]');
    } catch {
      return;
    }
    if (words.length < 2) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let i = 0;
    const tick = () => {
      span.classList.add('is-out');
      window.setTimeout(() => {
        i = (i + 1) % words.length;
        span.textContent = words[i];
        span.classList.remove('is-out');
        span.classList.add('is-in');
        requestAnimationFrame(() => {
          span.classList.remove('is-in');
        });
      }, 220);
    };
    const id = window.setInterval(tick, 2400);
    document.addEventListener('astro:before-swap', () => window.clearInterval(id), { once: true });
  }
  setupRotator();
  document.addEventListener('astro:page-load', setupRotator);
</script>
