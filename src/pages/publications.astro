---
import Base from '../layouts/Base.astro';
import PublicationItem from '../components/PublicationItem.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('publications', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// group by year
const byYear = new Map<number, typeof all>();
for (const p of all) {
  const y = p.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Publications" description="Peer-reviewed and preprint research on LLM reasoning, hallucination, and calibration." width="prose">
  <section class="pb-6">
    <h1 class="text-3xl font-semibold tracking-tight reveal">Publications</h1>
    <p class="mt-3 text-sm reveal" style="color: var(--color-fg-muted);">
      Research on LLM reasoning, hallucination mitigation, and confidence calibration.
      Most recent first.
    </p>
  </section>

  {years.map((year) => (
    <section class="pt-6">
      <div class="mb-2 flex items-baseline gap-3 reveal">
        <h2 class="text-xs font-semibold tracking-widest" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
          {year}
        </h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>
      <div class="divide-y" style="border-color: var(--color-border);">
        {byYear.get(year)!.map((p) => <PublicationItem pub={p} />)}
      </div>
    </section>
  ))}

  {all.length === 0 && (
    <p class="pt-10 text-sm" style="color: var(--color-fg-muted);">Nothing here yet.</p>
  )}
</Base>
