---
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { coverImage, neighbors, readingTime, relatedProjects } from '../../utils/project';

export const getStaticPaths = (async () => {
  const projects = await getCollection('projects', (p) => !p.data.draft);
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p, all: projects },
  }));
}) satisfies GetStaticPaths;

const { project, all } = Astro.props;
const { Content, headings } = await render(project);
const { title, summary, date, category, tech, tags, status, links } = project.data;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
const cover = coverImage(project);
const mins = readingTime(project);
const { prev, next } = neighbors(all, project);
const related = relatedProjects(all, project, 3);

const linkList = [
  links.github && { label: 'GitHub', href: links.github },
  links.demo && { label: 'Live demo', href: links.demo },
  links.paper && { label: 'Paper', href: links.paper },
  links.docs && { label: 'Docs', href: links.docs },
  links.external && { label: 'Link', href: links.external },
].filter(Boolean) as { label: string; href: string }[];

// Only show the TOC if the post has at least 3 H2s — shorter pages don't benefit.
const toc = headings.filter((h) => h.depth === 2);
const showToc = toc.length >= 3;
---

<Base title={title} description={summary} image={cover}>
  <article>
    <a href="/projects" class="inline-block text-xs link-underline" style="font-family: var(--font-mono); color: var(--color-fg-muted);">
      ← all projects
    </a>

    <header class="mt-6 mb-10">
      <div class="mb-3 flex items-center gap-2 text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
        <span>{category}</span>
        <span>·</span>
        <span>{dateStr}</span>
        <span>·</span>
        <span>{mins} min read</span>
        {status !== 'shipped' && (
          <>
            <span>·</span>
            <span style={status === 'in-progress' ? 'color: var(--color-accent);' : ''}>{status}</span>
          </>
        )}
      </div>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-4 text-base sm:text-lg" style="color: var(--color-fg-muted);">
        {summary}
      </p>

      {tech.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-1.5">
          {tech.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}

      {linkList.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-3">
          {linkList.map((l) => (
            <a
              href={l.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 rounded-md border px-3 py-1.5 text-xs transition-colors hover:bg-[var(--color-surface)]"
              style="border-color: var(--color-border-strong); font-family: var(--font-mono);"
            >
              {l.label} ↗
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- scroll progress bar -->
    <div class="scroll-progress" id="scroll-progress"></div>

    {showToc && (
      <aside class="toc hidden xl:block" aria-label="Table of contents">
        <p class="toc-title">On this page</p>
        <ol class="toc-list">
          {toc.map((h) => (
            <li>
              <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>{h.text}</a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <div class="prose-custom">
      <Content />
    </div>

    {tags.length > 0 && (
      <div class="mt-16 hairline pt-8">
        <div class="flex flex-wrap gap-1.5">
          {tags.map((t) => <span class="tag">#{t}</span>)}
        </div>
      </div>
    )}

    <!-- Prev / Next navigation -->
    <Lightbox />

    {related.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-5 text-xs font-semibold tracking-widest uppercase" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
          Related projects
        </h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {related.map((p) => <ProjectCard project={p} variant="compact" />)}
        </div>
      </section>
    )}

    {(prev || next) && (
      <nav class="mt-16 grid gap-4 sm:grid-cols-2" aria-label="Project navigation">
        {prev ? (
          <a href={`/projects/${prev.id}`} class="nav-card nav-prev group">
            <span class="nav-label">← Previous project</span>
            <span class="nav-title">{prev.data.title}</span>
            <span class="nav-category">{prev.data.category}</span>
          </a>
        ) : <span />}
        {next ? (
          <a href={`/projects/${next.id}`} class="nav-card nav-next group sm:text-right">
            <span class="nav-label">Next project →</span>
            <span class="nav-title">{next.data.title}</span>
            <span class="nav-category">{next.data.category}</span>
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</Base>

<style>
  /* Scroll progress bar */
  .scroll-progress {
    position: fixed;
    top: 3.5rem;
    left: 0;
    height: 2px;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent), rgba(255, 106, 31, 0.3));
    z-index: 50;
    transition: width 60ms linear;
  }

  /* TOC — only shown on xl screens (≥1280px) */
  .toc {
    position: fixed;
    top: 6rem;
    right: max(1.5rem, calc((100vw - 48rem) / 2 - 14rem));
    width: 14rem;
    max-height: calc(100vh - 9rem);
    overflow-y: auto;
    padding-right: 0.5rem;
  }
  .toc-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
    margin-bottom: 0.75rem;
  }
  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-border);
  }
  .toc-link {
    display: block;
    padding: 0.15rem 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--color-fg-muted);
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .toc-link:hover {
    color: var(--color-fg);
  }
  .toc-link.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  /* Nav cards */
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    border-radius: 0.75rem;
    transition: all 200ms ease;
  }
  .nav-card:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .nav-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
  }
  .nav-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.3;
  }
  .nav-card:hover .nav-title {
    color: var(--color-accent);
  }
  .nav-category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
  }
</style>

<script>
  // scroll progress
  const bar = document.getElementById('scroll-progress');
  if (bar) {
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
      bar.style.width = `${pct}%`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // highlight active TOC link via IntersectionObserver on h2s
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  if (tocLinks.length > 0) {
    const linkBySlug = new Map<string, HTMLAnchorElement>();
    tocLinks.forEach((l) => {
      const slug = l.dataset.slug;
      if (slug) linkBySlug.set(slug, l);
    });
    const headings = document.querySelectorAll<HTMLElement>('.prose-custom h2[id]');
    if (headings.length > 0) {
      const visible = new Set<string>();
      const update = () => {
        // pick topmost visible
        let activeSlug: string | null = null;
        let topmost = Infinity;
        visible.forEach((slug) => {
          const el = document.getElementById(slug);
          if (!el) return;
          const t = el.getBoundingClientRect().top;
          if (t < topmost) {
            topmost = t;
            activeSlug = slug;
          }
        });
        linkBySlug.forEach((link, slug) => {
          link.classList.toggle('is-active', slug === activeSlug);
        });
      };
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            const id = (e.target as HTMLElement).id;
            if (e.isIntersecting) visible.add(id);
            else visible.delete(id);
          }
          update();
        },
        { rootMargin: '-20% 0px -60% 0px', threshold: 0 },
      );
      headings.forEach((h) => io.observe(h));
    }
  }
</script>
