---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// group by year
const byYear = new Map<number, typeof all>();
for (const p of all) {
  const y = p.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Base title="Projects" description="A list of things I've built.">
  <section class="pb-6">
    <h1 class="text-3xl font-semibold tracking-tight reveal">Projects</h1>
    <p class="mt-3 text-sm reveal" style="color: var(--color-fg-muted);">
      A running list of things I've built, written, or researched.
    </p>
  </section>

  {years.map((year) => (
    <section class="pt-10 pb-2">
      <div class="mb-4 flex items-baseline gap-3 reveal">
        <h2 class="text-xs font-semibold tracking-widest" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
          {year}
        </h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>
      <ul class="divide-y" style="border-color: var(--color-border);">
        {byYear.get(year)!.map((p) => (
          <li class="reveal">
            <a href={`/projects/${p.id}`} class="group grid grid-cols-[1fr_auto] items-baseline gap-4 py-4 sm:grid-cols-[1fr_auto_auto]">
              <div class="min-w-0">
                <h3 class="truncate text-base font-medium transition-colors group-hover:text-[var(--color-accent)]">
                  {p.data.title}
                </h3>
                <p class="mt-1 truncate text-sm" style="color: var(--color-fg-muted);">
                  {p.data.summary}
                </p>
              </div>
              <span class="hidden shrink-0 text-xs sm:inline" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
                {p.data.category}
              </span>
              <span class="shrink-0 text-xs transition-transform group-hover:translate-x-0.5" style="color: var(--color-fg-dim);">
                →
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  {all.length === 0 && (
    <p class="pt-10 text-sm" style="color: var(--color-fg-muted);">Nothing here yet.</p>
  )}
</Base>
