---
import Base from '../layouts/Base.astro';
import { site } from '../config';

const skills = [
  { group: 'Languages', items: ['C/C++', 'Python', 'Rust', 'Go', 'Java', 'MATLAB', 'SQL', 'Bash', 'RISC-V Assembly'] },
  { group: 'Robotics & ML', items: ['ROS2', 'Gazebo', 'RViz2', 'Foxglove', 'MoveIt', 'SLAM', 'PyTorch', 'JAX', 'OpenCV'] },
  { group: 'Systems', items: ['Linux', 'Docker', 'CUDA', 'AWS (EC2)', 'AzureML', 'Kubernetes', 'Jenkins', 'Spark'] },
];

const education = [
  {
    degree: 'MEng Mechanical Engineering — Control & Robotics',
    school: 'UC Berkeley',
    period: '2025 — May 2026',
    detail: 'GPA: 3.77',
  },
  {
    degree: 'BS Electrical Engineering & Computer Science',
    school: 'UC Berkeley',
    period: '2021 — Dec 2024',
    detail: 'GPA: 3.73 · HKN EECS Honor Society',
  },
];

const experience = [
  {
    role: 'ML Engineer (Computer Vision)',
    org: 'IntuigenceAI',
    where: 'San Francisco, CA',
    period: 'Jan 2025 — Mar 2026',
    bullets: [
      'Converted P&ID schematics into knowledge graphs representing industrial process topology.',
      'Developed graph algorithms to detect faulty components and infer valid configurations under changing valve states.',
      'Built GPU training + inference pipelines on Azure for scalable vision model development.',
    ],
  },
  {
    role: 'Research Assistant — Autonomous Race Car',
    org: 'UC Berkeley',
    where: 'Berkeley, CA',
    period: 'Jun 2023 — Dec 2024',
    bullets: [
      'Progress-based Model Predictive Controller using CasADi and ACADOS.',
      'Trained a transformer policy via DAgger to imitate MPC trajectories for faster inference.',
    ],
  },
  {
    role: 'Research Assistant — BAIR Lab',
    org: 'UC Berkeley',
    where: 'Berkeley, CA',
    period: 'Jan 2023 — Dec 2024',
    bullets: [
      'JAX autonomous driving simulator with vehicle dynamics and multi-agent traffic.',
      'Trained PPO policies for lane-keeping and trajectory stabilization.',
    ],
  },
];
---

<Base title="About" description={site.description}>
  <!-- Intro -->
  <section class="pb-12">
    <figure class="portrait-wrap reveal">
      <img src="/images/parham.jpg" alt="Parham Sharafoleslami" class="portrait" />
    </figure>

    <p class="mb-3 text-xs reveal" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
      <span style="color: var(--color-accent);">●</span> {site.location}
    </p>

    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl reveal">About</h1>

    <div class="prose-custom mt-6 max-w-none reveal">
      <p>
        I'm Parham — an engineer and researcher at UC Berkeley working across autonomy,
        controls, and machine learning. My work lives between robots that move safely
        through the world and the learned systems deciding what they should do next.
      </p>
      <p>
        BS in EECS (Dec 2024), finishing an MEng in Control & Robotics in May 2026.
        Currently a computer vision ML engineer at IntuigenceAI; previously worked on
        an autonomous race car at Berkeley and spent two years at the Berkeley AI
        Research (BAIR) lab.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-3 reveal">
      <a href={site.links.resume} download class="inline-flex items-center gap-2 rounded-md border px-4 py-2 text-sm transition-colors hover:bg-[var(--color-accent-soft)]" style="border-color: var(--color-accent); color: var(--color-accent);">
        <span>↓ Download resume</span>
      </a>
      <a href={`mailto:${site.email}`} class="rounded-md border px-4 py-2 text-sm transition-colors hover:bg-[var(--color-surface)]" style="border-color: var(--color-border-strong);">
        Email me
      </a>
      <a href={site.links.github} class="rounded-md border px-4 py-2 text-sm transition-colors hover:bg-[var(--color-surface)]" style="border-color: var(--color-border-strong); color: var(--color-fg-muted);">
        GitHub ↗
      </a>
      <a href={site.links.linkedin} class="rounded-md border px-4 py-2 text-sm transition-colors hover:bg-[var(--color-surface)]" style="border-color: var(--color-border-strong); color: var(--color-fg-muted);">
        LinkedIn ↗
      </a>
    </div>
  </section>

  <!-- Experience -->
  <section class="pb-12">
    <h2 class="section-head reveal">Experience</h2>
    <ol class="mt-6 space-y-8">
      {experience.map((e) => (
        <li class="reveal grid gap-2 sm:grid-cols-[9rem_1fr]">
          <div class="text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
            {e.period}
          </div>
          <div>
            <div class="flex flex-wrap items-baseline gap-x-3">
              <h3 class="text-base font-semibold" style="color: var(--color-fg);">{e.role}</h3>
              <span class="text-sm" style="color: var(--color-accent);">{e.org}</span>
              <span class="text-xs" style="color: var(--color-fg-dim); font-family: var(--font-mono);">{e.where}</span>
            </div>
            <ul class="mt-3 space-y-1.5 text-sm" style="color: var(--color-fg-muted);">
              {e.bullets.map((b) => <li class="leading-relaxed">· {b}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Education -->
  <section class="pb-12">
    <h2 class="section-head reveal">Education</h2>
    <ol class="mt-6 space-y-6">
      {education.map((e) => (
        <li class="reveal grid gap-2 sm:grid-cols-[9rem_1fr]">
          <div class="text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">
            {e.period}
          </div>
          <div>
            <h3 class="text-base font-semibold" style="color: var(--color-fg);">{e.degree}</h3>
            <p class="text-sm" style="color: var(--color-accent);">{e.school}</p>
            <p class="mt-1 text-xs" style="color: var(--color-fg-muted); font-family: var(--font-mono);">{e.detail}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- Skills -->
  <section class="pb-12">
    <h2 class="section-head reveal">Toolbox</h2>
    <div class="mt-6 space-y-5">
      {skills.map((s) => (
        <div class="reveal grid gap-2 sm:grid-cols-[9rem_1fr]">
          <div class="text-xs" style="font-family: var(--font-mono); color: var(--color-fg-dim);">{s.group}</div>
          <div class="flex flex-wrap gap-1.5">
            {s.items.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Currently -->
  <section class="pb-12 reveal">
    <h2 class="section-head">Currently</h2>
    <div class="prose-custom mt-6">
      <p>
        Working on decentralized fleet coordination for airport ground operations (MAPPO + Buffered Voronoi Cells),
        finishing an MEng thesis in controls, and pushing on LLM reasoning research with the Algoverse group.
        See the <a href="/now">now</a> page for the current-week details.
      </p>
    </div>
  </section>
</Base>

<style>
  .section-head {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-fg-dim);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Circular portrait at the top */
  .portrait-wrap {
    margin: 0 0 1.75rem 0;
  }
  .portrait {
    width: 7.5rem;
    height: 7.5rem;
    object-fit: cover;
    border-radius: 9999px;
    border: 2px solid var(--color-border-strong);
    box-shadow: 0 14px 40px -20px rgba(0, 0, 0, 0.7);
    transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
  }
  .portrait:hover {
    transform: scale(1.03);
    border-color: var(--color-accent);
    box-shadow: 0 18px 50px -18px rgba(255, 106, 31, 0.5);
  }
</style>
